// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// 1. ENTIDADES PRINCIPALES
// ------------------------------------------------------

model Joven {
  id                          Int               @id @default(autoincrement())
  rut                         String?          @unique
  nombre                      String
  fechaNacimiento             DateTime
  genero                      String
  email                       String?           
  telefono                    String?
  direccion                   String?           
  idExcel                     String?           // Solo para la migración
  bautizado                   Boolean           @default(false)
  vivio110                    Boolean           @default(false)  
  tieneBibliaFisica           Boolean           @default(false)  
  
  // Ficha Familiar y Emergencias
  nombrePadre                 String?           
  rutPadre                    String?           
  telefonoPapa                String?
  direccionPadre              String?           
  
  nombreMadre                 String?           
  rutMadre                    String?           
  telefonoMama                String?
  direccionMadre              String?           

  nombreExtra                 String?           
  parentescoExtra             String?           
  telefonoExtra               String?           

  // Ficha Médica
  previsionSalud              String?           
  centroSalud                 String?
  tipoSangre                  String?           
  enfermedadesCronicas        String?           
  tratamientos                String?           
  medicamentosContraindicados String?    
  alimentosContraindicados    String?    
  estudio                     String            @default("Sin Estudio")

  // Relaciones
  grupoId                     Int
  grupo                       Grupo             @relation(fields: [grupoId], references: [id])
  
  asistencias                 Asistencia[]
  ministerios                 JovenMinisterio[]
}

model Grupo {
  id          Int      @id @default(autoincrement())
  numero      Int      @unique // Ej: 1, 2, 3... 12
  descripcion String?  // Ej: "14 años", "15 años", "23-24 años"
  
  jovenes     Joven[]  // Un grupo tiene muchos jóvenes
}

model Reunion {
  id            Int      @id @default(autoincrement())
  fecha         DateTime @unique
  dia           String?
  
  // Reflejando la columna "Prédica / Taller"
  tipo          String   @default("Prédica") 
  
  // Para diferenciar Reunión del Estudio Bíblico
  categoria     String   @default("Reunión")

  predicador    String?
  tituloMensaje String?
  
  // Reflejando las columnas de actividades booleanas
  huboJuego     Boolean  @default(false)
  huboObra      Boolean  @default(false)

  // Las relaciones de quiénes asistieron
  asistencias   Asistencia[]
}

model Ministerio {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique // Ej: "Música", "Teatro"
  
  integrantes JovenMinisterio[]
}

// ------------------------------------------------------
// 2. TABLAS INTERMEDIAS (Para las relaciones Muchos-a-Muchos)
// ------------------------------------------------------

// Tabla puente para saber quién fue a qué reunión
model Asistencia {
  jovenId   Int
  reunionId Int

  joven     Joven   @relation(fields: [jovenId], references: [id])
  reunion   Reunion @relation(fields: [reunionId], references: [id])

  @@id([jovenId, reunionId]) // La llave primaria es la combinación de ambos
}

// Tabla puente para saber quién está en qué ministerio
model JovenMinisterio {
  jovenId      Int
  ministerioId Int

  joven        Joven      @relation(fields: [jovenId], references: [id])
  ministerio   Ministerio @relation(fields: [ministerioId], references: [id])

  @@id([jovenId, ministerioId])
}

// ------------------------------------------------------
// 3. SEGURIDAD Y ACCESO AL SISTEMA
// ------------------------------------------------------

model UsuarioSistema {
  id                 Int       @id @default(autoincrement())
  nombre_completo    String
  correo             String    @unique
  password_hash      String
  rol                String    // Ej: "editor" o "lector"
  activo             Boolean   @default(true)
  reset_token        String?
  reset_token_expira DateTime?
}